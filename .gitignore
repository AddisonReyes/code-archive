venv/
env/
.venv/
lib/
lib64/
include/
bin/
share/

# Editors and IDEs (optional, uncomment as needed)
# VS Code
.vscode/

# PyCharm
.idea/

# Jupyter Notebook
.ipynb_checkpoints

# Miscellaneous
# OS generated files
.DS_Store
Thumbs.db

# Test coverage output
.coverage

# Specific tool caches (optional)
.pytest_cache/
.ruff_cache/

# Runtime data/logs (optional)
*.log
